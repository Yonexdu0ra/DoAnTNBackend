model Department {
  id          String     @id @default(uuid(7))
  name        String
  description String?
  positions   Position[] @relation("DepartmentPositions")
  users       User[]     @relation("DepartmentUsers")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
}
